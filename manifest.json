{
  "manifest_version": 3,
  "name": "KSTable Engine",
  "version": "2.22",
  "icons": {
    "48": "icons/KSIcon-48.png",
    "96": "icons/KSIcon-96.png"
  },
  "permissions": [
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "tailwind-3-min.css"
      ],
      "js": [
        "injectStart.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "injectEnd.js"
      ],
      "run_at": "document_end"
    }
  ],
  "content_scripts1": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "tailwind-3-min.css"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "kstable.js",
        "ksheader.js",
        "kstablecomp.js",
        "tailwind-3-min.css",
        "KSTableComponents.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kstable-public@keshavsoft.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}