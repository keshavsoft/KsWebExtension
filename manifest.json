{
  "manifest_version": 3,
  "name": "KSTable Engine",
  "version": "2.25",
  "icons": {
    "48": "icons/KSIcon-48.png",
    "96": "icons/KSIcon-96.png"
  },
  "permissions": [
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "src/tailwind-3-min.css"
      ],
      "js": [
        "src/injectStart.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/injectEnd.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/ksheader.js",
        "src/kstablecomp.js",
        "src/tailwind-3-min.css",
        "src/KSComponents.js",
        "src/ksvertical.js",
        "src/kstableonly.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kstable-public@keshavsoft.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "120.0"
    }
  }
}