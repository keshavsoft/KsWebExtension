{
  "manifest_version": 3,
  "name": "KSTable Engine",
  "version": "1.0",

  "permissions": ["scripting"],

"content_scripts": [
  {
    "matches": ["http://localhost/*", "https://keshavsoft.com/*"],
    "js": ["inject.js"],
    "run_at": "document_start"
  }
],

  "web_accessible_resources": [
    {
      "resources": ["kstable.js"],
     "matches": ["http://localhost/*", "https://keshavsoft.com/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
        "id": "kstable@keshavsoft.com",
      "data_collection_permissions": {
            "required": ["none"],
            "optional": []
        }
    }
}
}